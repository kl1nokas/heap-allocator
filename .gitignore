# ============================================================================
# .gitignore - Files and directories to ignore in Git
# ============================================================================

# ============================================================================
# Build directories
# ============================================================================
build/              # CMake build directory
cmake-build-*/      # CLion/CMake build directories
out/                # Generic output directory
bin/                # Binary output directory
lib/                # Library output directory
obj/                # Object files directory

# ============================================================================
# IDE and Editor files
# ============================================================================

# Visual Studio
.vs/                # Visual Studio settings
*.sln               # Solution files
*.vcxproj           # Project files
*.vcxproj.filters   # Project filters
*.vcxproj.user      # User-specific settings
Debug/              # Debug build output
Release/            # Release build output
x64/                # 64-bit build output
x86/                # 32-bit build output

# Visual Studio Code
.vscode/            # VS Code settings
*.code-workspace    # VS Code workspace

# CLion
.idea/              # CLion/IntelliJ IDEA settings
cmake-build-debug/  # CLion debug build
cmake-build-release/# CLion release build

# Qt Creator
*.user              # Qt Creator user settings
*.creator           # Qt Creator project files

# Code::Blocks
*.cbp               # Code::Blocks project
*.depend            # Dependencies

# Eclipse
.project            # Eclipse project file
.classpath          # Eclipse classpath
.cproject           # Eclipse C/C++ project

# ============================================================================
# Compiled files
# ============================================================================

# Object files
*.o
*.obj
*.ko
*.gch
*.pch

# Executables
*.exe
*.exe~
*.out
*.app
*.dll
*.so
*.dylib
*.a
*.lib
*.dSYM/

# Debug symbols
*.pdb
*.idb
*.ilk
*.map

# ============================================================================
# System files
# ============================================================================

# Windows
Thumbs.db
Thumbs.db:encryptable
desktop.ini
ehthumbs.db
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
*.swp
*.swo
*~

# Linux
.directory
*.pid
*.lock

# ============================================================================
# Build artifacts
# ============================================================================

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake
!CMakeLists.txt
!*.cmake.in
!cmake/modules/*.cmake

# Generated files
*.generated
config.h
stamp-h1

# Package managers
vcpkg_installed/
conanbuildinfo.*
conaninfo.txt
conan_imports_*

# ============================================================================
# Test and coverage files
# ============================================================================

# Test outputs
*.test
*.tests
*.result
*.xml
coverage/
*.gcno
*.gcda
*.gcov
*.profraw

# ============================================================================
# Logs and temporary files
# ============================================================================

# Logs
*.log
*.tmp
*.temp
*.bak
*.backup
*.swp
*.swo

# Crash dumps
*.dmp
*.core
core.*

# ============================================================================
# Project specific
# ============================================================================

# Custom build output
heap_allocator
heap_allocator_debug
allocator_tests
allocator_tests_debug

# User configuration
config.local.h
*.local.h

# Doxygen documentation
docs/html/
docs/latex/
*.docset